+    case 'Bash': {
+      const cmd = typeof input.command === 'string' ? input.command.trim() : '';
+      if (!cmd) return null;
+      const words = cmd.split(/\s+/);
+      // command word + subcommand when it looks like `git push`, `pnpm build` …
+      const head = words.slice(0, 2).join(' ');
+      return first(head, 30);
+    }
+    case 'Read':
+    case 'Write':
+    case 'Edit':
+      return base(input.file_path);
+    case 'Glob':
+    case 'Grep':
+      return first(input.pattern, 30);
+    case 'WebSearch':
+      return first(input.query, 40);
+    case 'WebFetch':
+      try {
+        return typeof input.url === 'string' ? new URL(input.url).hostname : null;
+      } catch {
+        return null;
+      }
+    case 'Task':
+      return first(input.description, 40);
+    default:
+      return null;
+  }
+}
