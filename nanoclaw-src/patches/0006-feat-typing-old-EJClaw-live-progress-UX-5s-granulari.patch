+function toolLogDetail(toolName: string, input: Record<string, unknown> | undefined): string | null {
+  if (!input) return null;
+  const first = (s: unknown, n = 40): string | null =>
+    typeof s === 'string' && s.trim() ? s.trim().slice(0, n) : null;
+  const base = (s: unknown): string | null => (typeof s === 'string' && s ? (s.split('/').pop() ?? null) : null);
