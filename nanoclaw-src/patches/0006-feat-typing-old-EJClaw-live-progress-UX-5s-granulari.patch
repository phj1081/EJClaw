+export interface ToolLogRow {
+  seq: number;
+  tool: string;
+  detail: string | null;
+  started_at: string;
+}
+
+/**
+ * EYEJOKER carry: tail of the container's rolling tool-activity log (oldest
+ * first). Empty array when the table is missing (older session DBs).
+ */
+export function getToolLogTail(outDb: Database.Database, limit: number): ToolLogRow[] {
+  try {
+    const rows = outDb
+      .prepare(`SELECT seq, tool, detail, started_at FROM tool_log ORDER BY seq DESC LIMIT ?`)
+      .all(limit) as ToolLogRow[];
+    return rows.reverse();
+  } catch {
+    return [];
+  }
+}
