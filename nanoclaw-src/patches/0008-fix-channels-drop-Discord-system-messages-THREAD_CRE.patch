From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: EJ Claw <ejclaw@eyejoker.com>
Date: Tue, 14 Jul 2026 17:54:36 +0900
Subject: [PATCH 8/8] fix(channels): drop Discord system messages
 (THREAD_CREATED etc.) before routing

Discord posts a type-18 THREAD_CREATED system message in the parent channel
whose content is the thread name; @chat-adapter/discord treats it as a user
message, so the agent replied to thread titles in the main channel. Filter
GATEWAY_MESSAGE_CREATE to real user content types (0 DEFAULT, 19 REPLY).
Live-verified: type 18/21 dropped in log, no bot reply in parent channel.
---
 src/channels/chat-sdk-bridge.ts | 15 +++++++++++++++
 1 file changed, 15 insertions(+)

diff --git a/src/channels/chat-sdk-bridge.ts b/src/channels/chat-sdk-bridge.ts
index b61aef7d..f03dca8c 100644
--- a/src/channels/chat-sdk-bridge.ts
+++ b/src/channels/chat-sdk-bridge.ts
@@ -655,6 +655,21 @@ async function handleForwardedEvent(
     return;
   }
 
+  // EYEJOKER carry: drop Discord SYSTEM messages before they reach the
+  // adapter. When a user creates a thread, Discord posts a type-18
+  // THREAD_CREATED system message in the PARENT channel whose `content` is
+  // the thread name. @chat-adapter/discord's handleForwardedMessage never
+  // checks `type`, so that system message routes as a normal user message
+  // in the parent channel and the agent replies to the thread *title* in
+  // the main channel. Keep only real user content: 0 DEFAULT, 19 REPLY.
+  if (event.type === 'GATEWAY_MESSAGE_CREATE' && event.data) {
+    const msgType = (event.data as { type?: unknown }).type;
+    if (typeof msgType === 'number' && msgType !== 0 && msgType !== 19) {
+      log.info('Dropping Discord system message', { messageType: msgType });
+      return;
+    }
+  }
+
   // Handle interaction events (button clicks) — not handled by adapter's handleForwardedGatewayEvent
   if (event.type === 'GATEWAY_INTERACTION_CREATE' && event.data) {
     const interaction = event.data;
