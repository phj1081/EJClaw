 }
 
+/**
+ * EYEJOKER carry v2: append one row to the full activity log.
+ * kind: 'tool' | 'text' | 'agent_start' | 'agent_done'
+ * agentId: 'main' for the root agent, or the Task tool_use id for a subagent.
+ * detail is pre-sanitized/short. Trimmed to the latest 100 rows.
+ */
+export function appendActivity(kind: string, agentId: string, tool: string | null, detail: string | null): void {
+  const db = getOutboundDb();
+  db.prepare(`INSERT INTO activity_log (kind, agent_id, tool, detail, started_at) VALUES (?, ?, ?, ?, ?)`).run(
+    kind,
+    agentId,
+    tool,
+    detail,
+    new Date().toISOString(),
+  );
+  db.prepare(`DELETE FROM activity_log WHERE seq <= (SELECT MAX(seq) FROM activity_log) - 100`).run();
+}
