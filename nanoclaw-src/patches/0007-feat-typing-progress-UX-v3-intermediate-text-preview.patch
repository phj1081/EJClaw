+    // EYEJOKER carry v2: mirror the SDK message stream into activity_log —
+    // the same event source the old EJClaw message-turn-controller consumed.
+    // Task tool_use ids identify subagents; assistant messages carry
+    // parent_tool_use_id so subagent activity is attributed to its track.
+    const knownTaskIds = new Set<string>();
+    function recordActivity(message: unknown): void {
+      const m = message as {
+        type?: string;
+        parent_tool_use_id?: string | null;
+        message?: { content?: unknown };
+      };
+      const blocks = Array.isArray(m.message?.content) ? (m.message.content as Array<Record<string, unknown>>) : [];
+      if (m.type === 'assistant') {
+        const agentId = m.parent_tool_use_id ?? 'main';
+        for (const block of blocks) {
+          if (block.type === 'text' && typeof block.text === 'string') {
+            let t = block.text.trim();
+            // Skip delivery envelopes — the host renders those as the real
+            // reply; previewing them would duplicate the final message.
+            if (!t || t.startsWith('<message')) continue;
+            // Scratchpad/internal markers are noise in a preview — unwrap.
+            t = t
+              .replace(/<\/?internal>/g, '')
+              .replace(/\s+/g, ' ')
+              .trim();
+            if (t) appendActivity('text', agentId, null, t.slice(0, 100));
+          } else if (block.type === 'tool_use' && typeof block.name === 'string') {
+            const input = (block.input ?? {}) as Record<string, unknown>;
+            // Subagent spawn: named 'Task' in older SDKs, 'Agent' in newer ones.
+            if ((block.name === 'Task' || block.name === 'Agent') && typeof block.id === 'string') {
+              knownTaskIds.add(block.id);
+              const label =
+                (typeof input.description === 'string' && input.description.trim().slice(0, 40)) ||
+                (typeof input.prompt === 'string' && input.prompt.trim().replace(/\s+/g, ' ').slice(0, 40)) ||
+                null;
+              appendActivity('agent_start', block.id, block.name, label);
+            } else {
+              appendActivity('tool', agentId, block.name, toolLogDetail(block.name, input));
+            }
+          }
+        }
+      } else if (m.type === 'user') {
+        for (const block of blocks) {
+          if (
+            block.type === 'tool_result' &&
+            typeof block.tool_use_id === 'string' &&
+            knownTaskIds.has(block.tool_use_id)
+          ) {
+            knownTaskIds.delete(block.tool_use_id);
+            appendActivity('agent_done', block.tool_use_id, 'Task', null);
+          }
+        }
+      }
+    }
