+/**
+ * EYEJOKER carry: an unfinished processing_ack claim means the container is
+ * mid-turn (thinking between tool calls leaves both the heartbeat and
+ * container_state quiet). Bounded by age so a crashed container's orphan
+ * claim can't keep typing alive forever — host-sweep clears those anyway.
+ */
+const CLAIM_FRESH_MS = 30 * 60_000;
+function turnActive(agentGroupId: string, sessionId: string): boolean {
+  try {
+    const outDb = openOutboundDb(agentGroupId, sessionId);
+    try {
+      const claims = getProcessingClaims(outDb);
+      const now = Date.now();
+      return claims.some((c) => {
+        const t = Date.parse(c.status_changed);
+        return !Number.isNaN(t) && now - t < CLAIM_FRESH_MS;
+      });
+    } finally {
+      outDb.close();
+    }
+  } catch {
+    return false;
+  }
+}
