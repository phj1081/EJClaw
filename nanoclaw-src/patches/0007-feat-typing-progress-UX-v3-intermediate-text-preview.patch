+export interface ActivityRow {
+  seq: number;
+  kind: string; // 'tool' | 'text' | 'agent_start' | 'agent_done'
+  agent_id: string; // 'main' or Task tool_use id
+  tool: string | null;
+  detail: string | null;
+  started_at: string;
+}
+
+/**
+ * EYEJOKER carry v2: tail of the container's full activity log (oldest
+ * first). Empty array when the table is missing (older session DBs).
+ */
+export function getActivityTail(outDb: Database.Database, limit: number): ActivityRow[] {
+  try {
+    const rows = outDb
+      .prepare(`SELECT seq, kind, agent_id, tool, detail, started_at FROM activity_log ORDER BY seq DESC LIMIT ?`)
+      .all(limit) as ActivityRow[];
+    return rows.reverse();
+  } catch {
+    return [];
+  }
+}
