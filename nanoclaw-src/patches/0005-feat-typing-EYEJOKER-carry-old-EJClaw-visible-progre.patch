+// ── EYEJOKER carry: visible progress message ─────────────────────────
+// Old-EJClaw style "⏳ 작업 중 — N분 · 도구" message: posted after
+// PROGRESS_AFTER_MS of continuous work, edited every PROGRESS_EDIT_MS,
+// deleted when the turn's real answer is delivered (see
+// pauseTypingRefreshAfterDelivery). Best-effort: any failure disables
+// the progress message for the rest of the turn but never breaks typing.
+
+/** Max in-flight window for a tool with no declared timeout. */
+const TOOL_IN_FLIGHT_DEFAULT_MS = 10 * 60_000;
+/** Slack past a declared timeout before we stop trusting container_state. */
+const TOOL_IN_FLIGHT_SLACK_MS = 60_000;
+
+interface ToolInFlight {
+  tool: string;
+}
+
+/**
+ * EYEJOKER carry: during a long blocking tool call (e.g. a 3-minute Bash
+ * build) the container's poll-loop heartbeat goes stale even though the
+ * agent is very much working. container_state (written by the SDK
+ * PreToolUse/PostToolUse hooks) is the authoritative "tool in flight"
+ * signal — trust it while within the tool's declared timeout (+slack),
+ * or a default cap when no timeout was declared.
+ */
+function toolInFlight(agentGroupId: string, sessionId: string): ToolInFlight | null {
+  try {
+    const outDb = openOutboundDb(agentGroupId, sessionId);
+    try {
+      const st = getContainerState(outDb);
+      if (!st?.current_tool || !st.tool_started_at) return null;
+      const startedAt = Date.parse(st.tool_started_at);
+      if (Number.isNaN(startedAt)) return null;
+      const windowMs =
+        st.tool_declared_timeout_ms != null
+          ? st.tool_declared_timeout_ms + TOOL_IN_FLIGHT_SLACK_MS
+          : TOOL_IN_FLIGHT_DEFAULT_MS;
+      if (Date.now() - startedAt > windowMs) return null;
+      return { tool: st.current_tool };
+    } finally {
+      outDb.close();
+    }
+  } catch {
+    return null;
+  }
+}
+
+function toolLabelKo(tool: string | null | undefined): string {
+  if (!tool) return '';
+  const KO: Record<string, string> = {
+    Bash: '명령 실행',
+    Read: '파일 읽기',
+    Write: '파일 쓰기',
+    Edit: '파일 수정',
+    Glob: '파일 탐색',
+    Grep: '코드 검색',
+    WebSearch: '웹 검색',
+    WebFetch: '웹 조회',
+    Task: '서브에이전트',
+  };
+  const name = KO[tool] ?? (tool.startsWith('mcp__') ? 'MCP 도구' : tool);
+  return ` · ${name}`;
+}
+
+function progressBody(entry: TypingTarget, sessionId: string): string {
+  const mins = Math.max(1, Math.round((Date.now() - entry.startedAt) / 60_000));
+  const inFlight = toolInFlight(entry.agentGroupId, sessionId);
+  return `⏳ 작업 중 — ${mins}분 경과${toolLabelKo(inFlight?.tool)}`;
+}
+
+function tickProgress(sessionId: string, entry: TypingTarget): void {
+  if (!adapter?.deliver || entry.progressPosting) return;
+  const now = Date.now();
+  if (now - entry.startedAt < PROGRESS_AFTER_MS) return;
+
+  const send = (operation: 'post' | 'edit') => {
+    entry.progressPosting = true;
+    const content =
+      operation === 'edit'
+        ? JSON.stringify({ operation: 'edit', messageId: entry.progressMsgId, text: progressBody(entry, sessionId) })
+        : JSON.stringify({ text: progressBody(entry, sessionId) });
+    adapter!.deliver!(
+      entry.channelType,
+      entry.platformId,
+      entry.threadId,
+      'message',
+      content,
+      undefined,
+      entry.instance,
+    )
+      .then((msgId) => {
+        if (operation === 'post' && msgId) entry.progressMsgId = msgId;
+        entry.progressLastEditAt = Date.now();
+      })
+      .catch(() => {
+        // Editing a deleted message / adapter hiccup: stop trying this turn.
+        entry.progressMsgId = entry.progressMsgId ?? 'failed';
+        entry.progressLastEditAt = Number.MAX_SAFE_INTEGER;
+      })
+      .finally(() => {
+        entry.progressPosting = false;
+      });
+  };
+
+  if (!entry.progressMsgId) {
+    send('post');
+  } else if (entry.progressMsgId !== 'failed' && now - entry.progressLastEditAt >= PROGRESS_EDIT_MS) {
+    send('edit');
+  }
+}
+
+function clearProgress(sessionId: string, entry: TypingTarget): void {
+  if (!entry.progressMsgId || entry.progressMsgId === 'failed' || !adapter?.deliver) {
+    entry.progressMsgId = null;
+    return;
+  }
+  const msgId = entry.progressMsgId;
+  entry.progressMsgId = null;
+  // Delete the placeholder outright (old-EJClaw behavior). Falls back to
+  // editing it to a checkmark if the adapter can't delete.
+  adapter
+    .deliver(
+      entry.channelType,
+      entry.platformId,
+      entry.threadId,
+      'message',
+      JSON.stringify({ operation: 'delete', messageId: msgId }),
+      undefined,
+      entry.instance,
+    )
+    .catch(() => {
+      adapter
+        ?.deliver?.(
+          entry.channelType,
+          entry.platformId,
+          entry.threadId,
+          'message',
+          JSON.stringify({ operation: 'edit', messageId: msgId, text: '✅ 완료' }),
+          undefined,
+          entry.instance,
+        )
+        .catch(() => {});
+    });
+}
+
 export function startTypingRefresh(
   sessionId: string,
   agentGroupId: string,
@@ -141,12 +307,21 @@ export function startTypingRefresh(
     if (entry.pausedUntil > Date.now()) return;
 
     const withinGrace = Date.now() - entry.startedAt < TYPING_GRACE_MS;
-    if (withinGrace || isHeartbeatFresh(entry.agentGroupId, sessionId)) {
+    // EYEJOKER carry: heartbeat goes stale during long blocking tool calls
+    // (poll-loop can't touch it mid-SDK-call) — container_state's tool-in-
+    // flight record covers that gap so typing + progress survive long Bash.
+    if (
+      withinGrace ||
