+      toolInFlight(entry.agentGroupId, sessionId) !== null
+    ) {
       triggerTyping(entry.channelType, entry.platformId, entry.threadId, entry.instance).catch(() => {});
+      tickProgress(sessionId, entry); // EYEJOKER carry
       return;
     }
 
     // Out of grace AND heartbeat stale — agent is idle, stop refreshing.
+    clearProgress(sessionId, entry); // EYEJOKER carry
     clearInterval(entry.interval);
     typingRefreshers.delete(sessionId);
   }, TYPING_REFRESH_MS);
@@ -161,6 +336,9 @@ export function startTypingRefresh(
     interval,
     startedAt,
     pausedUntil: 0,
+    progressMsgId: null,
+    progressLastEditAt: 0,
+    progressPosting: false,
   });
 }
 
@@ -174,11 +352,18 @@ export function pauseTypingRefreshAfterDelivery(sessionId: string): void {
   const entry = typingRefreshers.get(sessionId);
   if (!entry) return;
   entry.pausedUntil = Date.now() + POST_DELIVERY_PAUSE_MS;
+  // EYEJOKER carry: a real user-facing message just landed — the progress
+  // placeholder is obsolete. Also reset the elapsed-time base so a follow-up
+  // long stretch in the same session measures from the last delivery.
+  clearProgress(sessionId, entry);
+  entry.startedAt = Date.now();
+  entry.progressLastEditAt = 0;
 }
 
 export function stopTypingRefresh(sessionId: string): void {
   const entry = typingRefreshers.get(sessionId);
   if (!entry) return;
+  clearProgress(sessionId, entry); // EYEJOKER carry
   clearInterval(entry.interval);
   typingRefreshers.delete(sessionId);
 }
