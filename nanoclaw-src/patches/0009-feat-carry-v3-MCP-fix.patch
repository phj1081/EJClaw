+/**
+ * EYEJOKER carry v3: record the model the main agent is currently running on.
+ * `note` carries a transition label ("fable-5 → sonnet-4-5") or null for the
+ * initial set. Single row — the host reads it for the progress header.
+ */
+export function setModelState(model: string, note: string | null): void {
+  getOutboundDb()
+    .prepare(
+      `INSERT INTO model_state (id, model, note, updated_at) VALUES (1, ?, ?, ?)
+       ON CONFLICT(id) DO UPDATE SET
+         model = excluded.model,
+         note = excluded.note,
+         updated_at = excluded.updated_at`,
+    )
+    .run(model, note, new Date().toISOString());
+}
